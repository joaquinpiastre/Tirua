# Copia este archivo como .env y completa los valores.
# En Hostinger, configura estas variables en el panel de la aplicación Node.js o en el archivo .env del servidor.

# Base de datos PostgreSQL (Hostinger puede ofrecerla en el panel o usar una externa)
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST:5432/NOMBRE_BD?schema=public"

# URL del frontend (dominio público)
FRONTEND_URL=https://tallertirua.com

# URL del backend (para webhooks de Mercado Pago y CORS)
BACKEND_URL=https://tallertirua.com/api

# Puerto (Hostinger suele asignarlo automáticamente en Node.js)
PORT=5000

# Secreto para JWT (genera uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=tu_clave_secreta_muy_larga_y_aleatoria

# Mercado Pago (si usas pagos online)
MERCADOPAGO_ACCESS_TOKEN=tu_access_token_de_mercadopago

# Entorno
NODE_ENV=production
